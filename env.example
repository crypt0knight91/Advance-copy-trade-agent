# ════════════════════════════════════════════════════════════════
#  WHALE MIRROR BOT v2.1 — Configuration
#  Copy to .env and fill in your values
# ════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────
# Get from: reveal.magic.link/polymarket (Gmail account)
POLY_PRIVATE_KEY=0xYourPrivateKeyHere
MY_PROXY_WALLET=0xYourProxyWalletAddressHere

# ── OPTIONAL: auto-derived if blank ──────────────────────────────
POLY_API_KEY=
POLY_SECRET=
POLY_PASSPHRASE=

# ── MODE ─────────────────────────────────────────────────────────
DRY_RUN=true    # ALWAYS start true. Flip false only after testing.

# ── TRADING ──────────────────────────────────────────────────────
TRADE_SIZE_USD=4.0
CLUSTER_BOOST_USD=6.0       # $6 when 2+ whales agree
MAX_OPEN_POSITIONS=5
SL_PCT=0.27                 # -27% stop loss from entry
MAX_HOLD_HOURS=72.0         # force close after 72h
TP_RUNNER_PCT=9.0           # +900% = alert only, never auto-close

# ── TRUST SCORING ────────────────────────────────────────────────
# Lowered to practical levels — Polymarket API doesn't always return
# explicit PnL fields, so the scorer uses multiple fallback sources.
# Scoring sources tried in order:
#   1. Activity feed pnl/cashPnl fields (best)
#   2. Goldsky on-chain PnL subgraph
#   3. Inferred from BUY+SELL pairs on same market
#   4. Volume/frequency partial score (last resort)
MIN_TRUST_SCORE=0.35        # was 0.55 — realistic with fallback scoring
MIN_WR_15D=0.30             # was 0.65 — only applied when PnL data exists
LOOKBACK_DAYS=15
MIN_TRADES_FOR_WR=3         # was 5 — fewer needed to qualify
TRUST_RECHECK_MINS=30
MIN_WHALE_USD=10.0

# ── MARKET FILTERS ───────────────────────────────────────────────
MIN_VOLUME=2000.0
MAX_SPREAD_PCT=0.08
MAX_SLIP_CENTS=0.02
MIN_DEPTH_USD=200.0
MIN_HOURS_LEFT=6.0
MAX_YES_PRICE=0.92
PUMP_RATIO=10.0

# ── CLUSTER DETECTION ────────────────────────────────────────────
CLUSTER_SECS=300
CLUSTER_MIN=2

# ── LOSS PROTECTION ──────────────────────────────────────────────
DAILY_SOFT_PCT=0.10         # pause entries at -10% daily
DAILY_HARD_PCT=0.20         # full halt at -20% daily
TOTAL_HALT_PCT=0.40         # permanent halt at -40% total
BANKROLL=100.0

# ── POLLING ──────────────────────────────────────────────────────
POLL_SECS=5.0
SYNC_SECS=30.0

# ── DASHBOARD ────────────────────────────────────────────────────
DASHBOARD_PORT=8080

# ── TELEGRAM (optional) ──────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── WITHDRAWAL (Polymarket Polygon → Base chain) ─────────────────
# Set WITHDRAW_ENABLED=true to activate auto-withdrawal
WITHDRAW_ENABLED=false
WITHDRAW_THRESHOLD=100.0          # withdraw when balance reaches $100
WITHDRAW_AMOUNT=50.0              # withdraw this much each time
WITHDRAW_COOLDOWN_SECS=3600       # wait 1 hour between withdrawals
WITHDRAW_MIN_BUFFER=20.0          # always keep at least $20 in account
WITHDRAW_DESTINATION=0x1c6A81A22b97441E58c976819E9e413f28e35F18
